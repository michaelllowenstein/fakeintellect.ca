{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "../../..",
    "outDir": "../dist/api",
    "paths": {
      "@fakeintellect/types": ["../../../packages/types/src/index.ts"]
    }
  },
  "include": [
    "./**/*.ts",
    "../src/**/*.ts",
    "../../../packages/types/src/**/*.ts"
  ]
}