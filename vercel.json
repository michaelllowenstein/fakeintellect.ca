{
  "version": 2,
  "buildCommand": "npm run build --workspace=packages/types && npm run build --workspace=apps/web",
  "outputDirectory": "apps/web/dist/@fakeintellect/web",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/((?!_next|favicon|assets|.*\\..*).*)", "destination": "/index.html" }
  ]
}