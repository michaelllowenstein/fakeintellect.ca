{
  "name": "fakeintellect",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --workspace=server",
    "dev:web": "npm run start --workspace=client",
    "build": "npm run build --workspace=packages/types && npm run build --workspace=server && npm run build --workspace=client",
    "migrate": "npm run migrate --workspace=server",
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}